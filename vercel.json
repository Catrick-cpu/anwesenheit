{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "env": {
    "JWT_SECRET": {
      "description": "Secret key for JWT tokens (min 32 characters)",
      "required": true
    },
    "NEXT_PUBLIC_API_URL": {
      "description": "Public API URL",
      "required": false
    }
  }
}
